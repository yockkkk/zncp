.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #12122b 0%, #0d0d1e 100%);
  padding: 30rpx;
  box-sizing: border-box;
  color: #ffffff;
}

.glass-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  backdrop-filter: blur(20px);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

/* 用户卡片样式 */
.user-card {
  display: flex;
  align-items: center;
}

.avatar-area {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.2), rgba(0, 210, 255, 0.2));
  border: 2rpx solid rgba(64, 158, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  box-shadow: 0 0 20rpx rgba(64, 158, 255, 0.2);
}

.avatar-emoji {
  font-size: 60rpx;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.real-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-right: 16rpx;
}

.role-badge {
  background: linear-gradient(90deg, #409eff, #00d2ff);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
  box-shadow: 0 0 10rpx rgba(64, 158, 255, 0.5);
}

.username-label, .phone-label {
  color: #a0aec0;
  font-size: 24rpx;
  margin-top: 6rpx;
}

/* 业绩面板样式 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
  border-left: 6rpx solid #409eff;
  padding-left: 16rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.border-left {
  border-left: 1px solid rgba(255, 255, 255, 0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #409eff;
  margin-bottom: 8rpx;
  text-shadow: 0 0 10rpx rgba(64, 158, 255, 0.2);
}

.stat-label {
  color: #718096;
  font-size: 22rpx;
}

/* 修改表单样式 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  color: #a0aec0;
  font-size: 24rpx;
  margin-bottom: 12rpx;
  display: block;
}

.profile-input {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.profile-input:focus {
  border-color: rgba(64, 158, 255, 0.4);
  background: rgba(255, 255, 255, 0.06);
}

.btn-save {
  background: linear-gradient(135deg, #409eff, #2f80ed);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  margin-top: 30rpx;
  box-shadow: 0 6rpx 16rpx rgba(64, 158, 255, 0.25);
  border: none;
}

.btn-save:active {
  transform: scale(0.98);
}

/* 退出登录 */
.logout-area {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn-logout {
  background: rgba(229, 62, 62, 0.15);
  border: 1px solid rgba(229, 62, 62, 0.3);
  color: #fc8181;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 16rpx rgba(229, 62, 62, 0.1);
  border: none;
}

.btn-logout:active {
  background: rgba(229, 62, 62, 0.25);
}
