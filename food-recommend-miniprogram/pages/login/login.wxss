.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #12122b 0%, #0d0d1e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.logo-area {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 0 20rpx rgba(64, 158, 255, 0.3));
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0px); }
}

.app-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
  margin-bottom: 8rpx;
}

.app-subtitle {
  color: #718096;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.login-card {
  width: 100%;
  max-width: 650rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20px);
}

.login-tabs {
  display: flex;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  color: #a0aec0;
  font-size: 30rpx;
  padding-bottom: 24rpx;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #409eff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: linear-gradient(90deg, #409eff, #00d2ff);
  border-radius: 2rpx;
  box-shadow: 0 0 10rpx rgba(64, 158, 255, 0.8);
}

.form-panel {
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.wx-tips {
  display: flex;
  background: rgba(64, 158, 255, 0.05);
  border: 1px solid rgba(64, 158, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 60rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tips-text {
  color: #cbd5e0;
  font-size: 24rpx;
  line-height: 1.6;
}

.btn-wx-login {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx 0;
  line-height: 1.5;
  box-shadow: 0 10rpx 20rpx rgba(46, 204, 113, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-wx-login:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(46, 204, 113, 0.2);
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  color: #a0aec0;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  display: block;
}

.login-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  height: 90rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.login-input:focus {
  border-color: rgba(64, 158, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 12rpx rgba(64, 158, 255, 0.2);
}

.btn-pwd-login {
  background: linear-gradient(135deg, #409eff, #2f80ed);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx 0;
  line-height: 1.5;
  margin-top: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(64, 158, 255, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.btn-pwd-login:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(64, 158, 255, 0.2);
}

.agreement-area {
  margin-top: 60rpx;
  width: 100%;
  max-width: 650rpx;
  display: flex;
  justify-content: center;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
  cursor: pointer;
}

.agreement-checkbox {
  transform: scale(0.8);
  margin-top: 4rpx;
  margin-right: 12rpx;
}

.agreement-text {
  color: #718096;
  font-size: 24rpx;
  line-height: 1.4;
}

.agreement-link {
  color: #409eff;
  display: inline;
}
